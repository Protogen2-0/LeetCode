function compareVersion(version1: string, version2: string): number {
    let arr1 = version1.split(".")
    let arr2 = version2.split('.')
    let difLen = arr2.length - arr1.length
    if(difLen){
        if(difLen > 0){
            while(difLen){
                arr1.push("0")
                difLen--
            }
        }
        else{
            while(difLen){
                arr2.push("0")
                difLen++
            }
        }
    }
    for(let i = 0; i < arr1.length; i++){
        if( +arr1[i] > +arr2[i] ) return 1
        if( +arr1[i] < +arr2[i] ) return -1
    }
    return 0
};
